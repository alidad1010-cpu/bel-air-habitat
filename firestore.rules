rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper function to check if user is admin (custom claim or ID check)
    function isAdmin() {
      return isAuthenticated() && (
        request.auth.token.role == 'ADMIN' || 
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    // Helper: Vérifie si l'utilisateur est propriétaire du document
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Helper: Vérifie si l'utilisateur est propriétaire ou admin
    function isOwnerOrAdmin(userId) {
      return isOwner(userId) || isAdmin();
    }

    // USERS COLLECTION
    // Users can read their own profile or all if admin. Only owner can write their profile.
    match /users/{userId} {
      allow read: if isAuthenticated() && (isOwner(userId) || isAdmin());
      allow create: if isAuthenticated() && request.auth.uid == userId;
      allow update: if isAuthenticated() && (
        request.auth.uid == userId || 
        isAdmin()
      );
      allow delete: if isAdmin();
    }

    // PROJECTS COLLECTION
    // Tous les utilisateurs authentifiés peuvent lire, mais seuls les propriétaires peuvent modifier
    // Les clients peuvent uniquement lire leurs propres projets et mettre à jour le statut pour validation
    // Les partenaires peuvent lire les projets où ils sont assignés et mettre à jour les bons de commande
    match /projects/{projectId} {
      allow read: if isAuthenticated() && (
        isAdmin() ||
        resource.data.createdByUserId == request.auth.uid ||
        !('createdByUserId' in resource.data) ||
        (request.auth.token.role == 'CLIENT' && resource.data.client.userId == request.auth.uid) ||
        (request.auth.token.role == 'PARTNER' &&
         resource.data.purchaseOrders != null &&
         resource.data.purchaseOrders.hasAny([request.auth.uid]))
      );
      allow create: if isAuthenticated() && (
        request.resource.data.createdByUserId == request.auth.uid ||
        !('createdByUserId' in request.resource.data)
      );
      allow update: if isAuthenticated() && (
        resource.data.createdByUserId == request.auth.uid ||
        !('createdByUserId' in resource.data) ||
        isAdmin() ||
        (request.auth.token.role == 'CLIENT' &&
         resource.data.client.userId == request.auth.uid &&
         request.resource.data.status == 'VALIDATED') ||
        (request.auth.token.role == 'PARTNER' &&
         resource.data.purchaseOrders != null &&
         resource.data.purchaseOrders.hasAny([request.auth.uid]))
      );
      allow delete: if isAuthenticated() && (
        resource.data.createdByUserId == request.auth.uid ||
        !('createdByUserId' in resource.data) ||
        isAdmin()
      );
    }

    // CLIENTS COLLECTION
    // Lecture pour tous les utilisateurs authentifiés, écriture limitée
    match /clients/{clientId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && (
        resource.data.createdByUserId == request.auth.uid ||
        !('createdByUserId' in resource.data) ||
        isAdmin()
      );
      allow delete: if isAuthenticated() && (
        resource.data.createdByUserId == request.auth.uid ||
        !('createdByUserId' in resource.data) ||
        isAdmin()
      );
    }

    // PARTNERS COLLECTION
    match /partners/{partnerId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && (
        resource.data.createdByUserId == request.auth.uid ||
        !('createdByUserId' in resource.data) ||
        isAdmin()
      );
      allow delete: if isAuthenticated() && (
        resource.data.createdByUserId == request.auth.uid ||
        !('createdByUserId' in resource.data) ||
        isAdmin()
      );
    }

    // EMPLOYEES COLLECTION
    // Lecture pour tous, modification/se suppression seulement pour admins
    match /employees/{employeeId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated(); // Autoriser création pour compatibilité
      allow update: if isAuthenticated() && (
        resource.data.createdByUserId == request.auth.uid ||
        !('createdByUserId' in resource.data) ||
        isAdmin()
      );
      allow delete: if isAdmin();
    }

    // EXPENSES COLLECTION
    // Lecture pour tous, écriture seulement pour propriétaire
    match /expenses/{expenseId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && (
        request.resource.data.createdByUserId == request.auth.uid ||
        !('createdByUserId' in request.resource.data)
      );
      allow update: if isAuthenticated() && (
        resource.data.createdByUserId == request.auth.uid ||
        !('createdByUserId' in resource.data) ||
        isAdmin()
      );
      allow delete: if isAuthenticated() && (
        resource.data.createdByUserId == request.auth.uid ||
        !('createdByUserId' in resource.data) ||
        isAdmin()
      );
    }

    // ATTENDANCES COLLECTION
    match /attendances/{attendanceId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && (
        resource.data.createdByUserId == request.auth.uid ||
        !('createdByUserId' in resource.data) ||
        isAdmin()
      );
      allow delete: if isAuthenticated() && (
        resource.data.createdByUserId == request.auth.uid ||
        !('createdByUserId' in resource.data) ||
        isAdmin()
      );
    }

    // PROSPECTS COLLECTION
    match /prospects/{prospectId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && (
        resource.data.createdByUserId == request.auth.uid ||
        !('createdByUserId' in resource.data) ||
        isAdmin()
      );
      allow delete: if isAuthenticated() && (
        resource.data.createdByUserId == request.auth.uid ||
        !('createdByUserId' in resource.data) ||
        isAdmin()
      );
    }

    // TEAM MESSAGES COLLECTION
    // Tous peuvent lire et créer, mais seulement l'auteur ou admin peut supprimer
    match /team_messages/{messageId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && (
        request.resource.data.authorId == request.auth.uid ||
        !('authorId' in request.resource.data)
      );
      allow update: if isAuthenticated() && (
        resource.data.authorId == request.auth.uid ||
        isAdmin()
      );
      allow delete: if isAuthenticated() && (
        resource.data.authorId == request.auth.uid ||
        isAdmin()
      );
    }

    // NOTIFICATIONS COLLECTION
    // Les utilisateurs peuvent lire leurs propres notifications
    match /notifications/{notificationId} {
      allow read: if isAuthenticated() && (
        resource.data.userId == request.auth.uid ||
        isAdmin()
      );
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && (
        resource.data.userId == request.auth.uid ||
        isAdmin()
      );
      allow delete: if isAuthenticated() && (
        resource.data.userId == request.auth.uid ||
        isAdmin()
      );
    }

    // MESSAGES COLLECTION (Client-Team Communication)
    match /messages/{messageId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && (
        request.resource.data.senderId == request.auth.uid
      );
      allow update: if isAuthenticated();
      allow delete: if isAuthenticated() && (
        resource.data.senderId == request.auth.uid ||
        isAdmin()
      );
    }

    // COMPANY DATA
    match /company/dashboard {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated(); // Autoriser écriture pour compatibilité
    }

    match /company/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin(); // Seulement admin pour données administratives
    }

    // DEFAULT DENY - Tout le reste est refusé
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
